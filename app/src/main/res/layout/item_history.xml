<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_auth_card"
    android:padding="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_profile_avatar"
        android:padding="10dp"
        android:src="@android:drawable/ic_media_play"
        android:contentDescription="Song"
        app:tint="#1DB954" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSongTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên bài hát"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvArtist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Ca sĩ"
            android:textColor="#BDBDC7"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPlayedAt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Thời gian nghe"
            android:textColor="#8C8C96"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvPlayCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_history_count"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:text="1 lần"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>